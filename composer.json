{
  "name": "milpa/oauth-providers",
  "description": "OAuth 2.0 / social-login provider protocol layer for the Milpa PHP framework: Google, GitHub, GitLab, Facebook, Apple, Twitch and the Telegram Login Widget \u2014 typed contracts, curl-based providers, immutable UserInfo DTOs.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rodrigo Vicente - TeamX Agency",
      "homepage": "https://teamx.agency"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65",
    "milpa/core": "*"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\OAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\OAuth\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
